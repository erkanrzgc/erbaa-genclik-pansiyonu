---
/**
 * Çerez/yerel depolama bilgilendirmesi — küçük köşe pop-up'ı (KVKK & ePrivacy).
 *
 * Site analitik/izleme çerezi KULLANMAZ; harita yalnız tıklayınca yüklenir.
 * Banner bir izleme kapısı değil, bilgilendirme + onay KAYDIDIR → tercih
 * `localStorage`'da saklanır → karar verilince BİR DAHA gösterilmez.
 * Footer'daki [data-cookie-settings] tekrar açar.
 *
 * CSP: inline <script> Astro tarafından hash'lenir, inline `style` yok → katı CSP uyumlu.
 */
---

<div
  class="cookie-pop"
  id="cookie-banner"
  role="dialog"
  aria-live="polite"
  aria-label="Çerez bilgilendirmesi"
  hidden
>
  <div class="cookie-pop__body">
    <span class="cookie-pop__icon" aria-hidden="true">🍪</span>
    <div class="cookie-pop__content">
      <p class="cookie-pop__title">Çerez bilgilendirmesi</p>
      <p class="cookie-pop__text">
        Bu sitede yalnızca <strong>zorunlu</strong> çerezler kullanılır; reklam veya izleme yoktur.
        <a href="/cerez">Detaylı bilgi</a>
      </p>
    </div>
  </div>
  <div class="cookie-pop__actions">
    <button type="button" class="cookie-pop__btn cookie-pop__btn--ghost" data-cookie-reject>
      Reddet
    </button>
    <button type="button" class="cookie-pop__btn cookie-pop__btn--primary" data-cookie-accept>
      Kabul Et
    </button>
  </div>
</div>

<script>
  (() => {
    const KEY = 'erbaa-cookie-consent';
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;

    const open = () => {
      banner.hidden = false;
    };
    const close = () => {
      banner.hidden = true;
    };
    const save = (value: string) => {
      try {
        localStorage.setItem(KEY, value);
      } catch {
        /* private mode / storage kapalı → sessiz geç */
      }
      close();
    };

    // Karar daha önce verilmişse pop-up BİR DAHA açılmaz.
    let consent: string | null = null;
    try {
      consent = localStorage.getItem(KEY);
    } catch {
      consent = null;
    }
    // Sayfa otursun, sonra fade ile belirsin → "zaten oradaydı" hissi olmasın
    if (!consent) setTimeout(open, 700);

    banner.querySelector('[data-cookie-accept]')?.addEventListener('click', () => save('accepted'));
    banner.querySelector('[data-cookie-reject]')?.addEventListener('click', () => save('rejected'));

    // Footer "Çerez Tercihleri" (ve gelecekteki tetikleyiciler) bandı yeniden açar.
    document.querySelectorAll('[data-cookie-settings]').forEach((el) =>
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      }),
    );
  })();
</script>

<style>
  /* Küçük, sol-alt köşe kartı — camsı/incelikli (sade bir bildirim) */
  .cookie-pop {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 70;
    width: min(21rem, calc(100vw - 2rem));
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: color-mix(in oklab, var(--color-surface) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg, 16px);
    box-shadow:
      0 1px 0 color-mix(in oklab, #fff 50%, transparent) inset,
      0 22px 48px -22px rgba(33, 27, 22, 0.55);
    padding: 1rem 1.1rem 1.05rem;
    /* Belirgin fade + yukarı süzülme (gecikmeli açılır → sayfaya sonradan "gelir") */
    animation: cookiePop 480ms var(--ease-out-expo) both;
  }
  .cookie-pop[hidden] {
    display: none;
  }

  .cookie-pop__body {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
  }
  .cookie-pop__icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 50%;
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in oklab, var(--color-accent) 22%, transparent);
    font-size: 1.05rem;
    line-height: 1;
  }
  .cookie-pop__title {
    margin: 0 0 0.2rem;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .cookie-pop__text {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.5;
    color: var(--color-muted);
  }
  .cookie-pop__text strong {
    color: var(--color-ink-soft);
  }
  .cookie-pop__text a {
    color: var(--color-accent-strong);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }

  .cookie-pop__actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }
  .cookie-pop__btn {
    border-radius: 999px;
    font-family: inherit;
    font-weight: 600;
    font-size: 0.84rem;
    padding: 0.5rem 1.15rem;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background-color var(--duration-fast) ease,
      color var(--duration-fast) ease, border-color var(--duration-fast) ease,
      box-shadow var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .cookie-pop__btn:active {
    transform: translateY(1px) scale(0.98);
  }
  .cookie-pop__btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  /* Birincil — site butonlarıyla aynı altın degrade + iç ışık */
  .cookie-pop__btn--primary {
    background-image: linear-gradient(
      180deg,
      color-mix(in oklab, var(--color-accent) 86%, #fff) 0%,
      var(--color-accent) 46%,
      var(--color-accent-strong) 100%
    );
    color: var(--color-on-accent);
    box-shadow:
      0 1px 0 color-mix(in oklab, #fff 26%, transparent) inset,
      0 6px 14px -8px color-mix(in oklab, var(--color-accent) 70%, transparent);
  }
  .cookie-pop__btn--primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 color-mix(in oklab, #fff 30%, transparent) inset,
      0 10px 20px -10px color-mix(in oklab, var(--color-accent) 75%, transparent);
  }
  .cookie-pop__btn--ghost {
    background-color: transparent;
    color: var(--color-ink-soft);
    border-color: var(--color-line);
  }
  .cookie-pop__btn--ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  /* Mobil: masaüstü köşe kartı yerine ALTA DOCK olmuş, üstü yuvarlatılmış banner
     (mobil-native kalıp). CTA şeridinin hemen üstünde; çentik güvenli alanını hesaba katar. */
  @media (max-width: 767px) {
    .cookie-pop {
      left: 0;
      right: 0;
      bottom: calc(4rem + env(safe-area-inset-bottom, 0));
      width: auto;
      border-radius: 18px 18px 0 0;
      border-left: none;
      border-right: none;
      border-bottom: none;
      padding: 0.95rem 1.1rem 1.05rem;
      box-shadow: 0 -14px 30px -20px rgba(33, 27, 22, 0.5);
    }
    /* Butonlar tam genişlik (dokunması kolay) */
    .cookie-pop__btn {
      flex: 1;
      padding: 0.62rem 1rem;
    }
  }

  @keyframes cookiePop {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie-pop {
      animation: none;
    }
  }
</style>
