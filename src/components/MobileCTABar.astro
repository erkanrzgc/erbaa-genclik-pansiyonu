---
import Icon from './Icon.astro';
import { telHref, waHref } from '../config/business';
---

<div class="mobile-cta" role="group" aria-label="Hızlı iletişim">
  <a class="mobile-cta__btn mobile-cta__call" href={telHref} aria-label="Telefonla ara">
    <Icon name="phone" size={20} />
    <span>Ara</span>
  </a>
  <a
    class="mobile-cta__btn mobile-cta__wa"
    href={waHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="WhatsApp'tan yaz"
  >
    <Icon name="whatsapp" size={20} />
    <span>WhatsApp</span>
  </a>
</div>

<style>
  .mobile-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 60;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-line);
    border-top: 1px solid var(--color-line);
    padding-bottom: env(safe-area-inset-bottom, 0);
    box-shadow: 0 -8px 24px -12px rgba(33, 27, 22, 0.3);
  }

  .mobile-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.95rem 1rem;
    font-weight: 600;
    font-size: 0.98rem;
    text-decoration: none;
  }
  .mobile-cta__call { background: var(--color-accent); color: #fff; }
  .mobile-cta__wa { background: #25d366; color: #07320f; }
  .mobile-cta__btn:active { filter: brightness(0.95); }

  /* İçerik çubuğun arkasında kalmasın */
  :global(body) { padding-bottom: 0; }
  @media (max-width: 767px) {
    :global(body) { padding-bottom: 4.25rem; }
  }
  /* Masaüstünde gizle (header + hero CTA yeterli) */
  @media (min-width: 768px) {
    .mobile-cta { display: none; }
  }
</style>
