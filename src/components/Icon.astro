const icon = icons[name] ?? { body: '' };
const isFill = icon.fill === true;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={isFill ? 'currentColor' : 'none'}
  stroke={isFill ? 'none' : 'currentColor'}
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  focusable="false"
  set:html={icon.body}
/>
