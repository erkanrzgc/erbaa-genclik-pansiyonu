---
import Icon from './Icon.astro';
import BrandMark from './BrandMark.astro';
import { business, telHref } from '../config/business';
---

<header class="site-header">
  <div class="site-header__inner container-px">
    <a href="#hero" class="brand" aria-label={`${business.name} ana sayfa`}>
      <BrandMark class="brand__mark" />
      <span class="brand__text">
        <span class="brand__name">Erbaa Gençlik</span>
        <span class="brand__sub">Pansiyon</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Ana menü">
      <a href="#odalar">Odalar</a>
      <a href="#konum">Konum</a>
      <a href="#iletisim">İletişim</a>
    </nav>

    <a class="btn btn-primary site-header__call" href={telHref} aria-label="Telefonla ara">
      <Icon name="phone" size={17} />
      <span class="site-header__call-text">Ara</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid color-mix(in oklab, var(--color-line) 70%, transparent);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-ink);
  }
  .brand__mark {
    height: 2.5rem;
    width: auto;
    flex: none;
    display: block;
  }
  .brand__text { display: flex; flex-direction: column; line-height: 1; }
  .brand__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.18rem;
    letter-spacing: -0.01em;
  }
  .brand__sub {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 2px;
  }

  .site-nav {
    display: none;
    gap: 1.8rem;
  }
  .site-nav a {
    color: var(--color-ink-soft);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.97rem;
    position: relative;
    padding-block: 0.3rem;
    transition: color var(--duration-fast) ease;
  }
  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--color-accent);
    transition: width var(--duration-normal) var(--ease-out-expo);
  }
  .site-nav a:hover { color: var(--color-accent-strong); }
  .site-nav a:hover::after { width: 100%; }

  .site-header__call { padding: 0.6rem 1.15rem; }

  /* Masaüstü: tam navigasyon görünür */
  @media (min-width: 768px) {
    .site-nav { display: flex; }
  }
  /* Çok küçük ekranda "Ara" metnini gizle, ikon kalsın */
  @media (max-width: 360px) {
    .site-header__call-text { display: none; }
  }
</style>
