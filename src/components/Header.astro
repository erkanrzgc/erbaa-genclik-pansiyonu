---
import Icon from './Icon.astro';
import BrandMark from './BrandMark.astro';
import { business, telHref } from '../config/business';
---

<header class="site-header">
  <div class="site-header__inner container-px">
    <a href="/" class="brand" aria-label={`${business.name} ana sayfa`}>
      <BrandMark class="brand__mark" />
      <span class="brand__text">
        <span class="brand__name">Erbaa Gençlik</span>
        <span class="brand__sub">Pansiyon</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Ana menü">
      <a href="/#odalar">Odalar</a>
      <a href="/#konum">Konum</a>
      <a href="/#iletisim">İletişim</a>
    </nav>

    <a class="btn btn-primary site-header__call" href={telHref} aria-label="Telefonla ara">
      <Icon name="phone" size={17} />
      <span class="site-header__call-text">Ara</span>
    </a>
  </div>
</header>

<script>
  // Aşağı kaydırınca başlığı gizle, yukarı kaydırınca geri getir (passive + rAF → akıcı).
  // Inline script Astro tarafından hash'lenir → katı CSP uyumlu (unsafe-inline gerekmez).
  const header = document.querySelector('.site-header');
  if (header) {
    const HIDE_AFTER = 140; // bu eşikten önce gizleme (hero üstünde başlık dursun)
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;
      header.classList.toggle('site-header--scrolled', y > 8);
      if (y > lastY && y > HIDE_AFTER) {
        header.classList.add('site-header--hidden'); // aşağı → gizle
      } else if (y < lastY) {
        header.classList.remove('site-header--hidden'); // yukarı → göster
      }
      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    /* Hero'dan bir tık koyu (kum tonu) → başlık zeminden ayrışır, karışmaz */
    background: color-mix(in oklab, var(--color-surface-2) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-line);
    transition: transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) ease,
      background-color var(--duration-normal) ease;
    will-change: transform;
  }
  /* Aşağı kaydırırken gizlen */
  .site-header--hidden {
    transform: translateY(-100%);
  }
  /* Sayfa kaydırılınca hafif gölge + biraz daha opak zemin (okunabilirlik) */
  .site-header--scrolled {
    background: color-mix(in oklab, var(--color-surface-2) 94%, transparent);
    box-shadow: 0 6px 24px -16px rgba(33, 27, 22, 0.5);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-ink);
  }
  .brand__mark {
    height: 2.5rem;
    width: auto;
    flex: none;
    display: block;
  }
  .brand__text { display: flex; flex-direction: column; line-height: 1; }
  .brand__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.18rem;
    letter-spacing: -0.01em;
  }
  .brand__sub {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-top: 2px;
  }

  .site-nav {
    display: none;
    gap: 1.8rem;
  }
  .site-nav a {
    color: var(--color-ink-soft);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.97rem;
    position: relative;
    padding-block: 0.3rem;
    transition: color var(--duration-fast) ease;
  }
  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--color-accent);
    transition: width var(--duration-normal) var(--ease-out-expo);
  }
  .site-nav a:hover { color: var(--color-accent-strong); }
  .site-nav a:hover::after { width: 100%; }

  .site-header__call { padding: 0.6rem 1.15rem; }

  /* Masaüstü: tam navigasyon görünür */
  @media (min-width: 768px) {
    .site-nav { display: flex; }
  }
  /* Çok küçük ekranda "Ara" metnini gizle, ikon kalsın */
  @media (max-width: 360px) {
    .site-header__call-text { display: none; }
  }
</style>
