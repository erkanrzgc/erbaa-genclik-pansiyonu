---
import { Image } from 'astro:assets';
import SpotlightCard from './reactbits/SpotlightCard.jsx';
import Icon from './Icon.astro';
import { rooms } from '../data/rooms';
import { telHref, waHrefForRoom } from '../config/business';
---

<section id="odalar" class="section rooms" aria-labelledby="rooms-title">
  <div class="container-px">
    <header class="section-head reveal">
      <p class="eyebrow">Odalarımız</p>
      <h2 id="rooms-title">Konforlu ve Tertemiz Odalar</h2>
      <p class="section-lead">
        Otel konforunda, tertemiz ve uygun fiyatlı odalar. Müsaitlik ve fiyat için
        bizi arayın ya da WhatsApp’tan yazın — size en uygun odayı birlikte bulalım.
      </p>
    </header>

    <ul class="rooms__grid" role="list">
      {
        rooms.map((room) => (
          <li class="rooms__item reveal">
            <SpotlightCard client:visible className={`room ${room.featured ? 'is-featured' : ''}`}>
              <div class="room__media">
                <Image
                  src={room.image}
                  alt={`${room.name} — Erbaa otel & pansiyon`}
                  widths={[400, 800]}
                  sizes="(min-width:768px) 46vw, 92vw"
                  loading="lazy"
                  class="room__img"
                />
                {room.featured && <span class="room__badge">Popüler</span>}
              </div>

              <div class="room__body">
                <h3 class="room__name">{room.name}</h3>
                <p class="room__desc">{room.description}</p>

                <ul class="room__amenities" role="list">
                  {room.amenities.map((a) => (
                    <li class="chip">
                      <Icon name={a.icon} size={15} />
                      {a.label}
                    </li>
                  ))}
                </ul>

                <div class="room__cta">
                  <a class="btn btn-primary room__btn" href={telHref} aria-label={`${room.name} için ara`}>
                    <Icon name="phone" size={16} />
                    Ara
                  </a>
                  <a
                    class="btn btn-ghost room__btn"
                    href={waHrefForRoom(room.name)}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${room.name} için WhatsApp'tan yaz`}
                  >
                    <Icon name="whatsapp" size={16} />
                    WhatsApp
                  </a>
                </div>
              </div>
            </SpotlightCard>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .rooms {
    background: var(--color-surface-2);
  }

  .section-head {
    max-width: 44rem;
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.25rem);
  }
  .section-head h2 {
    font-size: var(--text-h2);
    margin-top: 0.5rem;
  }
  .section-lead {
    margin-top: 0.9rem;
    color: var(--color-muted);
    font-size: var(--text-lead);
  }

  .rooms__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.1rem, 0.8rem + 1.5vw, 1.8rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .rooms__item {
    display: flex;
  }
  /* Scroll-reveal sıralı gecikme (inline --reveal-i yerine → sıkı CSP) */
  .rooms__item:nth-child(2) { --reveal-i: 1; }
  .rooms__item:nth-child(3) { --reveal-i: 2; }
  .rooms__item:nth-child(4) { --reveal-i: 3; }
  @media (min-width: 768px) {
    .rooms__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .rooms__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* React tarafından üretilen sarmalayıcı → :global gerekli */
  :global(.room) {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
    box-shadow: var(--shadow-soft);
    transition: box-shadow var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  :global(.room:hover) {
    box-shadow: var(--shadow-lift);
    transform: translateY(-4px);
  }
  :global(.room.is-featured) {
    border-color: color-mix(in oklab, var(--color-accent) 55%, var(--color-line));
  }

  .room__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .room__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-expo);
  }
  :global(.room:hover) .room__img {
    transform: scale(1.04);
  }
  .room__badge {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    z-index: 3;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    box-shadow: var(--shadow-soft);
  }

  .room__body {
    position: relative;
    z-index: 2;
    background: var(--color-surface);
    padding: 1.3rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
  }
  .room__name {
    font-size: var(--text-h3);
  }
  .room__desc {
    color: var(--color-muted);
    font-size: 0.97rem;
  }
  .room__amenities {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0.1rem 0 0;
    padding: 0;
  }
  .room__cta {
    display: flex;
    gap: 0.6rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  .room__btn {
    padding: 0.6rem 1.05rem;
    font-size: 0.9rem;
    flex: 1;
  }
</style>
