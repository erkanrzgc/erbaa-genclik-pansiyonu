---
/**
 * Oda galerisi lightbox'ı — TEK global örnek (CookieBanner gibi sayfada bir kez).
 *
 * Tıkla-büyüt + parmakla/okla kaydır. Slaytlar `#rooms-gallery` JSON adasından
 * (Rooms.astro üretir) okunur; her odanın optimize edilmiş WebP URL'leri + alt'ları.
 *
 * KAYDIRMA: CSS `scroll-snap` ile NATIVE yatay kaydırma → JS'ten inline `style`
 * set etMİYORUZ (transform yok). Konum değişimi `element.scrollTo()` (CSSOM) ile.
 * Böylece 'unsafe-inline' gerekmez → sıkı CSP korunur. Inline <script> Astro'ca hash'lenir.
 *
 * Açma: document üzerinde tek delegasyon dinleyicisi → `[data-open-gallery]`.
 * React (SpotlightCard) hidrasyonu DOM düğümünü değiştirse bile delegasyon dayanır.
 */
import Icon from './Icon.astro';
---

<div
  class="lightbox"
  id="lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Oda fotoğraf galerisi"
  hidden
>
  <div class="lightbox__backdrop" data-lb-close aria-hidden="true"></div>

  <div class="lightbox__dialog" role="document">
    <header class="lightbox__bar">
      <p class="lightbox__title" id="lightbox-title"></p>
      <p class="lightbox__counter" aria-live="polite">
        <span class="lightbox__cur">1</span>
        <span class="lightbox__sep">/</span>
        <span class="lightbox__total">1</span>
      </p>
      <button type="button" class="lightbox__icon-btn lightbox__close" data-lb-close aria-label="Galeriyi kapat">
        <Icon name="close" size={22} />
      </button>
    </header>

    <button
      type="button"
      class="lightbox__nav lightbox__nav--prev"
      data-lb-prev
      aria-label="Önceki fotoğraf"
    >
      <Icon name="chevronLeft" size={26} />
    </button>

    <div class="lightbox__track" id="lightbox-track" tabindex="0" aria-label="Fotoğraflar — yana kaydırın">
      <!-- Slaytlar JS ile eklenir -->
    </div>

    <button
      type="button"
      class="lightbox__nav lightbox__nav--next"
      data-lb-next
      aria-label="Sonraki fotoğraf"
    >
      <Icon name="chevronRight" size={26} />
    </button>

    <div class="lightbox__dots" id="lightbox-dots" role="tablist" aria-label="Fotoğraf seçici">
      <!-- Noktalar JS ile eklenir -->
    </div>
  </div>
</div>

<script>
  (() => {
    type Slide = { src: string; alt: string };
    type Gallery = { name: string; slides: Slide[] };

    const dataEl = document.getElementById('rooms-gallery');
    const overlay = document.getElementById('lightbox');
    const track = document.getElementById('lightbox-track');
    const dotsWrap = document.getElementById('lightbox-dots');
    if (!dataEl || !overlay || !track || !dotsWrap) return;

    let galleries: Record<string, Gallery> = {};
    try {
      galleries = JSON.parse(dataEl.textContent || '{}');
    } catch {
      return; // bozuk veri → galeri sessizce devre dışı
    }

    const titleEl = overlay.querySelector('.lightbox__title') as HTMLElement;
    const curEl = overlay.querySelector('.lightbox__cur') as HTMLElement;
    const totalEl = overlay.querySelector('.lightbox__total') as HTMLElement;

    let slides: Slide[] = [];
    let current = 0;
    let lastFocus: HTMLElement | null = null;

    const slideWidth = () => track.clientWidth || 1;

    const loadNear = () => {
      for (let i = current - 1; i <= current + 1; i++) {
        const fig = track.children[i] as HTMLElement | undefined;
        if (!fig) continue;
        const img = fig.querySelector('img');
        if (img && !img.src && img.dataset.src) img.src = img.dataset.src;
      }
    };

    const setCurrent = (i: number) => {
      const clamped = Math.max(0, Math.min(slides.length - 1, i));
      if (clamped !== current) current = clamped;
      curEl.textContent = String(current + 1);
      // Noktalar
      Array.from(dotsWrap.children).forEach((dot, idx) =>
        dot.classList.toggle('is-active', idx === current),
      );
      loadNear();
    };

    const goTo = (i: number, smooth = true) => {
      const clamped = Math.max(0, Math.min(slides.length - 1, i));
      track.scrollTo({ left: slideWidth() * clamped, behavior: smooth ? 'smooth' : 'auto' });
      setCurrent(clamped);
    };

    // Kaydırma sırasında aktif indeksi izle (rAF ile yumuşatılmış)
    let ticking = false;
    track.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        setCurrent(Math.round(track.scrollLeft / slideWidth()));
        ticking = false;
      });
    });

    const build = (g: Gallery) => {
      slides = g.slides;
      titleEl.textContent = g.name;
      totalEl.textContent = String(slides.length);
      track.replaceChildren();
      dotsWrap.replaceChildren();

      slides.forEach((s, i) => {
        const fig = document.createElement('figure');
        fig.className = 'lightbox__slide';
        const img = document.createElement('img');
        img.className = 'lightbox__img';
        img.alt = s.alt;
        img.decoding = 'async';
        img.dataset.src = s.src; // tembel: src loadNear ile atanır
        // Yüklenince fade-in (boş kare yerine spinner → yumuşak geçiş)
        img.addEventListener('load', () => fig.classList.add('is-loaded'), { once: true });
        fig.appendChild(img);
        track.appendChild(fig);

        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'lightbox__dot';
        dot.setAttribute('role', 'tab');
        dot.setAttribute('aria-label', `${i + 1}. fotoğraf`);
        dot.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(dot);
      });
    };

    const open = (id: string, startIndex = 0) => {
      const g = galleries[id];
      if (!g || !g.slides?.length) return;
      lastFocus = document.activeElement as HTMLElement;
      build(g);
      overlay.hidden = false;
      document.documentElement.classList.add('lb-open');
      // Düzen otursun, sonra hedef slayta atla (anında) + komşuları yükle
      requestAnimationFrame(() => {
        goTo(startIndex, false);
        (overlay.querySelector('.lightbox__close') as HTMLElement)?.focus();
      });
    };

    const close = () => {
      overlay.hidden = true;
      document.documentElement.classList.remove('lb-open');
      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
    };

    // Açış: tüm sayfada tek delegasyon (React düğüm değiştirse de dayanır)
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest('[data-open-gallery]');
      if (!trigger) return;
      e.preventDefault();
      const id = trigger.getAttribute('data-open-gallery') || '';
      const idx = Number(trigger.getAttribute('data-gallery-index') || '0');
      open(id, Number.isNaN(idx) ? 0 : idx);
    });

    // Kapatma kontrolleri (backdrop + kapat butonu)
    overlay.querySelectorAll('[data-lb-close]').forEach((el) =>
      el.addEventListener('click', close),
    );
    overlay.querySelector('[data-lb-prev]')?.addEventListener('click', () => goTo(current - 1));
    overlay.querySelector('[data-lb-next]')?.addEventListener('click', () => goTo(current + 1));

    // Klavye: Esc kapat, oklar gez, Tab tuzağı
    overlay.addEventListener('keydown', (e) => {
      if (overlay.hidden) return;
      if (e.key === 'Escape') {
        close();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        goTo(current + 1);
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        goTo(current - 1);
      } else if (e.key === 'Tab') {
        const focusables = Array.from(
          overlay.querySelectorAll<HTMLElement>('button:not([hidden]), [tabindex="0"]'),
        ).filter((el) => el.offsetParent !== null);
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Yeniden boyutlandırmada hizayı koru
    let resizeRaf = 0;
    window.addEventListener('resize', () => {
      if (overlay.hidden) return;
      cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => goTo(current, false));
    });
  })();
</script>

<style is:global>
  /* GLOBAL: slayt/görsel/nokta öğeleri JS ile (createElement) üretilir; Astro'nun
     scoped CSS'i (cid attribute) JS ile yaratılan öğelere uygulanmaz. Bu yüzden bu
     bileşenin stili global'dir. Class isimleri benzersiz `lightbox__*` ön ekli +
     keyframe'ler `lb*` → site geneliyle çakışma yok. (is-active/is-loaded daima
     `.lightbox__*` ile birleşik kullanılır, tek başına değil.) */

  /* Sayfa kaydırmasını kilitle (html'e sınıf → inline style yok) */
  html.lb-open {
    overflow: hidden;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: clamp(0.5rem, 0.2rem + 1.5vw, 1.5rem);
  }
  .lightbox[hidden] {
    display: none;
  }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklab, #14110d 86%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    animation: lbFade 240ms var(--ease-out-expo) both;
  }

  .lightbox__dialog {
    position: relative;
    z-index: 1;
    width: min(1100px, 100%);
    height: min(86vh, 100%);
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto 1fr auto;
    grid-template-areas:
      'bar  bar  bar'
      'prev view next'
      'dots dots dots';
    gap: 0.5rem 0.4rem;
    animation: lbRise 320ms var(--ease-out-expo) both;
  }

  .lightbox__bar {
    grid-area: bar;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #fff;
    padding: 0.15rem 0.25rem 0.35rem;
  }
  .lightbox__title {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 0.95rem + 0.6vw, 1.4rem);
    font-weight: 600;
    margin: 0;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lightbox__counter {
    margin: 0;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
    color: color-mix(in oklab, #fff 78%, transparent);
    letter-spacing: 0.02em;
  }
  .lightbox__sep {
    opacity: 0.5;
    margin: 0 0.15rem;
  }

  .lightbox__icon-btn {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, #fff 22%, transparent);
    background: color-mix(in oklab, #fff 10%, transparent);
    color: #fff;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .lightbox__icon-btn:hover {
    background: color-mix(in oklab, #fff 20%, transparent);
  }
  .lightbox__icon-btn:active {
    transform: scale(0.94);
  }
  .lightbox__icon-btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* Kaydırılabilir şerit (native scroll-snap → parmakla kaydırma) */
  .lightbox__track {
    grid-area: view;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-lg, 16px);
    overscroll-behavior: contain;
  }
  .lightbox__track::-webkit-scrollbar {
    display: none;
  }
  .lightbox__track:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .lightbox__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    margin: 0;
    scroll-snap-align: center;
    scroll-snap-stop: always;
    display: grid;
    place-items: center;
  }
  /* Yükleniyor spinner'ı — foto inene kadar ortada döner; inince kaybolur */
  .lightbox__slide::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: 3px solid color-mix(in oklab, #fff 22%, transparent);
    border-top-color: var(--color-gold);
    animation: lbSpin 0.8s linear infinite;
  }
  .lightbox__slide.is-loaded::after {
    content: none;
  }
  .lightbox__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.7);
    background: color-mix(in oklab, #fff 6%, transparent);
    /* Yüklenince fade-in (scale'i scroll animasyonu yönetir → çakışma yok) */
    opacity: 0;
    transform-origin: center;
    transition: opacity 0.45s var(--ease-out-expo);
  }
  .lightbox__slide.is-loaded .lightbox__img {
    opacity: 1;
  }

  /* Kaydırırken ortaya gelen foto büyüyüp odaklanır (scroll-bağlantılı, JS'siz) */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .lightbox__img {
        animation: lbFocus linear both;
        animation-timeline: view(inline);
      }
    }
  }
  @keyframes lbFocus {
    0%,
    100% {
      transform: scale(0.84);
    }
    50% {
      transform: scale(1);
    }
  }
  @keyframes lbSpin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Yan gezinme okları (masaüstü) */
  .lightbox__nav {
    align-self: center;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, #fff 22%, transparent);
    background: color-mix(in oklab, #14110d 45%, transparent);
    color: #fff;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .lightbox__nav--prev {
    grid-area: prev;
  }
  .lightbox__nav--next {
    grid-area: next;
  }
  .lightbox__nav:hover {
    background: color-mix(in oklab, #14110d 70%, transparent);
    transform: scale(1.06);
  }
  .lightbox__nav:active {
    transform: scale(0.95);
  }
  .lightbox__nav:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  /* Noktalar */
  .lightbox__dots {
    grid-area: dots;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.2rem;
  }
  .lightbox__dot {
    width: 0.55rem;
    height: 0.55rem;
    padding: 0;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    background: color-mix(in oklab, #fff 35%, transparent);
    transition:
      width var(--duration-normal) var(--ease-out-expo),
      background-color var(--duration-fast) ease;
  }
  .lightbox__dot:hover {
    background: color-mix(in oklab, #fff 60%, transparent);
  }
  /* Aktif nokta → altın pill (genişler) */
  .lightbox__dot.is-active {
    width: 1.5rem;
    background: var(--color-gold);
  }
  .lightbox__dot:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 3px;
  }

  /* Mobilde yan okları gizle — parmakla kaydırma + noktalar yeterli */
  @media (max-width: 640px) {
    .lightbox__nav {
      display: none;
    }
    .lightbox__dialog {
      grid-template-columns: 1fr;
      grid-template-areas:
        'bar'
        'view'
        'dots';
      height: min(92vh, 100%);
    }
  }

  @keyframes lbFade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes lbRise {
    from {
      opacity: 0;
      transform: translateY(14px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox__backdrop,
    .lightbox__dialog,
    .lightbox__slide::after {
      animation: none;
    }
    .lightbox__img {
      transition: none;
    }
    .lightbox__track {
      scroll-behavior: auto;
    }
  }
</style>
