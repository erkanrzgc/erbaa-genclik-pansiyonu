  <path d="M268 156 L300 156 L300 286 L284 312 L268 286 Z" />
  <path d="M380 156 L412 156 L412 286 L396 312 L380 286 Z" />
  <path d="M300 196 L380 196 L380 222 L300 222 Z" />
  <path d="M328 222 L352 222 L340 330 Z" />
</svg>
