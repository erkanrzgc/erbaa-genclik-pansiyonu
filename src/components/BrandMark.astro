---
/**
 * BrandMark — Erbaa Gençlik Pansiyon altın amblemi (saf vektör, sıfır JS).
 * Header + Footer'da "E" placeholder yerine kullanılır. Renk markaya sabit (altın).
 * Yanında her zaman etiketli link/metin olduğundan dekoratif → aria-hidden.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

