---
/**
 * Partners — rezervasyon platformları için kayan logo şeridi (marquee).
 *
 * Saf CSS animasyon (StarBorder deseni): SIFIR JS, inline style YOK → katı CSP uyumlu.
 * Logolar yerel/metin → img-src 'self' uyumlu. reduced-motion'da statik sıra.
 */
import { partners } from '../data/partners';

// Az öğe (3) → bir "yarı"yı geniş ekranı dolduracak kadar tekrarla.
const REPEATS = 6;
const half = Array.from({ length: REPEATS }, () => partners).flat();
// İki özdeş yarı → translateX(-50%) tam bir yarı kayar → kusursuz döngü.
const loop = [...half, ...half];
---

<section class="partners" aria-labelledby="partners-title">
  <div class="container-px partners__head reveal">
    <p class="eyebrow">Bizi Bulun</p>
    <h2 id="partners-title" class="partners__title">Bizi Bu Platformlarda Bulabilirsiniz</h2>
  </div>

  <div class="partners__viewport">
    <ul class="partners__track" role="list" aria-label="Rezervasyon platformları">
      {
        loop.map((p, i) => {
          // Yalnız ilk özgün set ekran okuyucu + klavye için; geri kalanı görsel kopya.
          const accessible = i < partners.length;
          return (
            <li class="partners__item" aria-hidden={accessible ? undefined : 'true'}>
              <a
                class:list={['partners__link', { 'partners__link--chip': p.chip }]}
                href={p.href}
                target="_blank"
                rel="noopener noreferrer"
                tabindex={accessible ? undefined : -1}
                aria-label={accessible ? `${p.name} (yeni sekmede açılır)` : undefined}
              >
                <img
                  class="partners__logo"
                  src={p.logo.src}
                  alt={accessible ? `${p.name} logosu` : ''}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .partners {
    padding-block: clamp(2.5rem, 2rem + 2vw, 4rem);
    /* Düz açık zemin → üstteki SSS (kum bandı) ile alternatif ritim.
       Rooms(kum) → Konum(açık) → SSS(kum) → Partners(açık) dizilimi. */
    background: var(--color-bg);
    border-block: 1px solid var(--color-line);
    scroll-margin-top: 5.5rem;
  }
  .partners .eyebrow {
    color: var(--color-accent);
  }

  .partners__head {
    text-align: center;
    margin-bottom: clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
  }
  .partners__title {
    font-size: var(--text-h3);
    margin-top: 0.4rem;
    color: var(--color-ink-soft);
  }

  /* Kenarlarda yumuşak silinme (ekstra DOM yok) */
  .partners__viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
  }

  .partners__track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: clamp(2rem, 1.4rem + 2.5vw, 4rem);
    margin: 0;
    padding: 0;
    list-style: none;
    animation: partners-scroll 42s linear infinite;
    will-change: transform;
  }
  /* Üzerine gelince duraklat (okumak için) */
  .partners__viewport:hover .partners__track {
    animation-play-state: paused;
  }

  .partners__item {
    flex: none;
  }
  .partners__link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    outline-offset: 6px;
  }
  /* Açık renkli logo (sarı Ucuzabilet) açık bantta silinir → altına küçük koyu chip. */
  .partners__link--chip {
    padding: 0.42rem 0.75rem;
    border-radius: 10px;
    background: var(--color-ink);
  }
  /* Logolar soluk/tek-renk durur → üzerine gelince/odakta kendi renklerine döner.
     (Marquee hover'da durduğu için düşük kontrast sorun değil.) */
  .partners__logo {
    display: block;
    height: clamp(1.5rem, 1.15rem + 1vw, 2.05rem);
    width: auto;
    filter: grayscale(1);
    opacity: 0.5;
    transition:
      filter var(--duration-normal) ease,
      opacity var(--duration-normal) ease,
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .partners__link:hover .partners__logo,
  .partners__link:focus-visible .partners__logo {
    filter: none;
    opacity: 1;
    transform: translateY(-2px);
  }

  @keyframes partners-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  /* Hareket azaltma: animasyonu durdur, kopyaları gizle, tek temiz sıra göster */
  @media (prefers-reduced-motion: reduce) {
    .partners__viewport {
      -webkit-mask-image: none;
      mask-image: none;
    }
    .partners__track {
      animation: none !important;
      transform: none !important;
      width: auto;
      flex-wrap: wrap;
      justify-content: center;
      row-gap: 1rem;
    }
    .partners__item[aria-hidden] {
      display: none;
    }
  }
</style>
