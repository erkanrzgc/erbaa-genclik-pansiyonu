---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero.jpg';
import StarBorder from './reactbits/StarBorder.jsx';
import Icon from './Icon.astro';
import { business, telHref, waHref } from '../config/business';
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="container-px hero__grid">
    <div class="hero__content">
      <p class="eyebrow hero__eyebrow">Erbaa · Tokat</p>

      <h1 id="hero-title" class="hero__title">
        Erbaa’da Otel Konforunda Konaklama
      </h1>

      <p class="hero__tagline">
        Tertemiz odalar, güler yüzlü hizmet ve uygun fiyatlarla şehrin
        merkezinde huzurlu bir konaklama.
      </p>

      <div class="hero__cta">
        <StarBorder as="a" href={telHref} className="hero__call" aria-label="Telefonla hemen arayın">
          <Icon name="phone" size={18} />
          Hemen Arayın
        </StarBorder>

        <a class="btn btn-whatsapp" href={waHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp'tan yazın">
          <Icon name="whatsapp" size={18} />
          WhatsApp
        </a>

        <a class="btn btn-ghost" href="#odalar">Odaları Gör</a>
      </div>

      <p class="hero__note">Fiyat ve müsaitlik için arayın ya da WhatsApp’tan yazın.</p>
    </div>

    <div class="hero__media">
      <Image
        src={heroImg}
        alt={`${business.name} — Erbaa, Tokat'taki binamızın dış cephesi`}
        widths={[420, 640, 900, 1200]}
        sizes="(min-width:900px) 44vw, 92vw"
        loading="eager"
        fetchpriority="high"
        class="hero__img"
      />
      <span class="hero__badge"><Icon name="mapPin" size={15} />Erbaa merkez</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--color-bg);
    color: var(--color-ink);
    overflow: hidden;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1.4rem + 3vw, 4rem);
    align-items: center;
    padding-block: clamp(2.6rem, 2rem + 5vh, 5.5rem);
  }
  @media (min-width: 900px) {
    .hero__grid {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }

  .hero__content {
    position: relative;
    z-index: 1;
  }
  .hero__eyebrow {
    color: var(--color-accent);
    margin-bottom: 0.9rem;
  }
  .hero__title {
    font-size: var(--text-hero);
    font-weight: 700;
    color: var(--color-ink);
    max-width: 14ch;
    animation: heroRise 0.9s var(--ease-out-expo) both;
  }
  .hero__tagline {
    margin-top: 1.1rem;
    max-width: 44ch;
    font-size: var(--text-lead);
    color: var(--color-muted);
    animation: heroRise 0.9s var(--ease-out-expo) 0.12s both;
  }

  .hero__cta {
    margin-top: 1.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }
  .hero__note {
    margin-top: 1.1rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .hero__media {
    position: relative;
    animation: heroFade 1s var(--ease-out-expo) 0.1s both;
  }
  .hero__img {
    width: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
    object-position: 50% 58%;
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in oklab, var(--color-accent) 30%, var(--color-line));
    box-shadow: 0 24px 50px -22px rgba(43, 38, 32, 0.42);
  }
  @media (min-width: 900px) {
    .hero__img {
      aspect-ratio: 4 / 5;
    }
  }
  .hero__badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(20, 17, 13, 0.66);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .hero__badge :global(svg) {
    color: var(--color-gold);
  }

  @keyframes heroRise {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes heroFade {
    from { opacity: 0; transform: scale(0.98); }
    to { opacity: 1; transform: none; }
  }
</style>
