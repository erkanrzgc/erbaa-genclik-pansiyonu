---
import { Image } from 'astro:assets';
import heroImg from '../assets/hero.jpg';
import StarBorder from './reactbits/StarBorder.jsx';
import Icon from './Icon.astro';
import { business, telHref, waHref } from '../config/business';
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__media">
    <Image
      src={heroImg}
      alt={`${business.name} — Erbaa'da temiz ve konforlu konaklama`}
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="hero__img"
    />
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__inner container-px">
    <p class="eyebrow hero__eyebrow">Erbaa · Tokat</p>

    <h1 id="hero-title" class="hero__title">
      Erbaa’da Temiz ve Konforlu Otel &amp; Pansiyon
    </h1>

    <p class="hero__tagline">
      Tertemiz odalar, otel konforu ve uygun fiyatlarla şehrin kalbinde huzurlu bir konaklama.
    </p>

    <div class="hero__cta">
      <StarBorder as="a" href={telHref} className="hero__call" aria-label="Telefonla hemen arayın">
        <Icon name="phone" size={18} />
        Hemen Arayın
      </StarBorder>

      <a class="btn btn-whatsapp" href={waHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp'tan yazın">
        <Icon name="whatsapp" size={18} />
        WhatsApp
      </a>

      <a class="btn btn-ghost hero__ghost" href="#odalar">Odaları Gör</a>
    </div>

    <p class="hero__note">Fiyat ve müsaitlik için arayın ya da WhatsApp’tan yazın.</p>
  </div>

  <a href="#odalar" class="hero__scroll" aria-label="Aşağı kaydır">
    <Icon name="arrowDown" size={22} />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(560px, 92svh, 940px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  /* Metin okunabilirliği için sıcak koyu vinyet (soldan ve alttan) */
  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(20, 14, 9, 0.58) 0%, rgba(20, 14, 9, 0.30) 42%, rgba(20, 14, 9, 0.93) 100%),
      linear-gradient(90deg, rgba(20, 14, 9, 0.66) 0%, rgba(20, 14, 9, 0.05) 62%);
  }

  .hero__inner {
    position: relative;
    padding-block: clamp(2.5rem, 2rem + 6vh, 6rem);
    color: #fff;
  }

  .hero__eyebrow {
    color: #dcc188;
    margin-bottom: 0.9rem;
  }

  .hero__title {
    font-size: var(--text-hero);
    max-width: 18ch;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.28);
    /* Saf CSS giriş — JS gerektirmez, reduced-motion ile anında görünür */
    animation: heroRise 0.9s var(--ease-out-expo) both;
  }

  .hero__tagline {
    margin-top: 1.1rem;
    max-width: 46ch;
    font-size: var(--text-lead);
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.3);
    animation: heroRise 0.9s var(--ease-out-expo) 0.15s both;
  }

  .hero__cta {
    margin-top: 1.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }

  .hero__ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.55);
  }
  .hero__ghost:hover {
    color: #fff;
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .hero__note {
    margin-top: 1.1rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.82);
  }

  .hero__scroll {
    position: absolute;
    bottom: 1.2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.85);
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    animation: scrollBob 2.2s ease-in-out infinite;
  }
  .hero__scroll:hover { color: #fff; border-color: #fff; }

  @keyframes heroRise {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes scrollBob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 6px); }
  }
</style>
